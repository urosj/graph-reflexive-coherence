    "transform_id": "string"
  },
  "compressed_signed_flux_formula": "sum signed flux per column, then uniformly split the signed total across the three ports in that column",
  "compressed_signed_flux_is_lossy": true,
  "compressed_signed_flux_lossy_error": 2.0833333333333335,
  "eligible_nonnegative_fields": [
    "conductance",
    "geometric_length",
    "temporal_delay",
    "flux_coupling",
    "abs_flux"
