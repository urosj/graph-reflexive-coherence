  "adaptive_topology_entry_allowed": false,
  "topology_policy": {
    "fixed_substrate_required": true,
    "topology_changed_required": false,
    "topology_changed_allowed": false
  },
  "metric_defaults": {
    "epsilon_budget": 1e-9,
    "configured_displacement_min": 0.05,
    "null_calibration_k": 3.0,
    "identity_mass_ratio_min": 0.95,
    "width_relative_change_max": 0.15,
    "profile_similarity_min": 0.8
  },
  "null_displacement_envelope": {
    "calibration_status": "pending_iteration_5",
    "calibrated": false,
    "mean": 0.0,
    "max": 0.0,
    "std": 0.0,
    "effective_displacement_min_rule": "max(configured_displacement_min, mean + null_calibration_k * std)",
    "effective_displacement_min": 0.05
  },
  "default_edge_properties": {
    "weight": 1.0,
    "base_conductance": 1.0,
    "temporal_delay": 1.0,
    "proper_time_delay": 1.0,
    "interpretation": "Unit coupling and unit edge delay for first fixed-substrate movement tranche unless an edge overrides these fields."
  },
  "initializer_defaults": {
    "baseline_coherence": 1.0,
    "bump_amplitude": 0.4,
    "tilt_epsilon": 0.02,
    "kick_mask_node_count": 1
  },
  "initializer_formulas": {
    "uniform": {
      "formula": "C_i = B / N",
      "projection": "conserved_nonnegative_simplex"
    },
    "symmetric_bump": {
      "formula": "C_i = C0 + A * exp(-d(i, center)^2 / (2 * sigma^2))",
      "projection": "conserved_nonnegative_simplex"
    },
    "locally_tapered_asymmetric_bump": {
      "formula": "C_i = C0 + A * exp(-d(i, center)^2 / (2 * sigma^2)) + epsilon * d_signed(i, center, direction) * exp(-d(i, center)^2 / (2 * sigma_tilt^2))",
      "projection": "conserved_nonnegative_simplex",
      "global_background_gradient_allowed": false
    },
    "zero_sum_kick": {
      "formula": "C_front += delta, C_rear -= delta over equal-size local masks",
      "projection": "conserved_nonnegative_simplex"
    }
  },
  "drive_type_definitions": {
    "none": "No active drive is applied after initialization.",
    "none_after_initialization": "The lane is initialized with a structured asymmetry and then evolves with no active drive, kick, or pulse.",
    "one_time_zero_sum_kick": "A single conserved zero-sum front/rear perturbation is applied at initialization and no repeated drive is applied afterward."
  },
