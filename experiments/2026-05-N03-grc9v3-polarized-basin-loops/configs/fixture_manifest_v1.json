  "initialization": {
    "coordinate": {
      "theta_i": "2*pi*i/N"
    },
    "projection": {
      "name": "nonnegative_conserved_simplex",
      "formula": "C_i >= 0; sum_i C_i = B"
    },
    "formulas": {
      "uniform": "C_i = B/N",
      "canonical_ring_bump": "C_i = C_0 + A * exp(kappa * cos(theta_i - theta_0)); then project to conserved simplex",
      "two_equal_canonical_ring_bumps": "Apply canonical_ring_bump twice with equal A and kappa at theta_0 values listed in lane.bump_centers; sum the two bumps with C_0 and project to conserved simplex",
      "canonical_ring_bump_plus_small_local_source_sink_modulation": "Apply canonical_ring_bump first, then add small_local_source_sink_modulation using source/sink masks, then project once to the conserved simplex; record pre-projection sum and projection delta",
      "small_local_source_sink_modulation": "C_i <- C_i + epsilon_s*m_s(i) - epsilon_k*m_k(i); then project to conserved simplex",
      "zero_sum_kick": "C_i <- C_i + delta*k_source(i) - delta*k_sink(i); then project to conserved simplex"
    },
    "default_parameters": {
      "C_0": 0.08333333333333333,
      "A": 0.02,
      "kappa": 3.0,
      "theta_0": 0.0,
      "epsilon_s": 0.01,
      "epsilon_k": 0.01,
      "kick_delta": 0.02
    }
  },
  "lanes": {
