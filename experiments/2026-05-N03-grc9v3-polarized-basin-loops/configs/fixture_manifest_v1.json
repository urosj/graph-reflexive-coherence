      "composition": "resolve base_lane U2, initialize uniform closed-substrate masks, then apply zero_sum_kick at kick_step",
      "external_source_sink_terms_enabled": false
    },
    "K_reversed": {
      "name": "one_time_zero_sum_kick_reversed",
